# Copy to .env and fill values
# Alpha Vantage API key (optional but recommended)
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here

# Postgres connection string (optional, for caching)
# Example: postgres://user:password@localhost:5432/marketdb
DATABASE_URL=postgres://user:password@localhost:5432/marketdb

# Gemini / Google GenAI key used by the LangChain agent
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (optional)
PORT=3001
